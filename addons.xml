<?xml version='1.0' encoding='utf-8'?>
<addons>
    <addon id="plugin.video.bootcamp_data_science" name="Bootcamp Data Science 2025 Vitoria-Gasteiz" version="1.1.2" provider-name="Eduardo">
        <requires>
            <import addon="xbmc.python" version="3.0.0" />
            <import addon="plugin.video.youtube" version="6.8.0" />
        </requires>
        <extension point="xbmc.python.pluginsource" library="default.py">
            <provides>video</provides>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary lang="es_ES">Clases del Bootcamp</summary>
            <description lang="es_ES">Acceso directo a los vídeosde las clases del Bootcamp Data Science 2025 Abril Vitoria-Gasteiz.
        También incluye canales de divulgación científica de Machine Learning e IA tanto en castellano como en inglés.
        Si quieres que se agreguen más canales, por favor contacta conmigo y lo implemento en una futura actualización.</description>
            <language>es</language>
            <platform>all</platform>
            <license>MIT</license>
            <assets>
                <icon>icon.png</icon>
                <screenshot>screenshot1.jpg</screenshot>
                <screenshot>screenshot2.jpg</screenshot>
                <screenshot>screenshot3.jpg</screenshot>
            </assets>
        </extension>
    </addon>
    <addon id="repository.bootcamp_ds" name="Repo Bootcamp Data Science" version="1.0.0" provider-name="Eduardo">
        <requires>
            <import addon="xbmc.addon" version="12.0.0" />
        </requires>
        <extension point="xbmc.addon.repository" name="Repo Bootcamp DS">
            <dir minversion="0.0.0">
                <info compressed="false">https://eortas.github.io/Kodi_BC/addons.xml</info>
                <checksum>https://eortas.github.io/Kodi_BC/addons.xml.md5</checksum>
                <datadir zip="true">https://eortas.github.io/Kodi_BC/</datadir>
            </dir>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary lang="es_ES">Repositorio Bootcamp Data Science</summary>
            <description lang="es_ES">Repositorio oficial del addon Bootcamp Data Science 2025 Vitoria-Gasteiz.</description>
            <platform>all</platform>
            <license>MIT</license>
        </extension>
    </addon>
</addons>